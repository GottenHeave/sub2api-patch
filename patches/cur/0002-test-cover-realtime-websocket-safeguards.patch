+func (c *openAIWSCaptureConn) Writes() []map[string]any {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	out := make([]map[string]any, len(c.writes))
+	for i := range c.writes {
+		out[i] = cloneMapStringAny(c.writes[i])
+	}
+	return out
+}

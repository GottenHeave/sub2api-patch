+func isOpenAIAudioTranscriptionSameAccountRetryable(account *Account, statusCode int) bool {
+	if account == nil {
+		return false
+	}
+	if account.Type == AccountTypeOAuth && statusCode >= 500 {
+		return true
+	}
+	return account.IsPoolMode() && isPoolModeRetryableStatus(statusCode)
+}

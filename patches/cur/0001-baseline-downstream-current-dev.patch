+		User:    user,
+		GroupID: &groupID,
+		Group:   group,
+	}
+	c.Set(string(middleware.ContextKeyAPIKey), apiKey)
+	c.Set(string(middleware.ContextKeyUser), middleware.AuthSubject{UserID: user.ID})
+	c.Set(string(middleware.ContextKeyUserRole), service.RoleUser)
+	return c, rec

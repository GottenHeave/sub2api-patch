+	ctx context.Context,
+	groupID *int64,
+	sessionHash string,
+	requestedModel string,
+	excludedIDs map[int64]struct{},
+) (*AccountSelectionResult, OpenAIAccountScheduleDecision, string, error) {
+	selection, decision, err := s.SelectAccountWithSchedulerForAccountType(
+		ctx,
